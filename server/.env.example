# Solana mainnet RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Path to the service wallet keypair JSON (Solana CLI format: array of 64 numbers)
SERVICE_WALLET_PATH=./_keys/service-wallet.json

# TxLINE mainnet TxL token mint (from docs/txline/programs/mainnet.md)
TXL_TOKEN_MINT=Zhw9TVKp68a1QrftncMSd6ELXKDtpVMNuMGr1jNwdeL

# WebSocket server port for frontend clients
WS_PORT=8787

# SQLite database file path
DB_PATH=./box-seat.db

# X (Twitter) API v2 bearer token for the match chatter feature — recent
# search only, read-only, never used for posting. Leave empty to keep chatter
# completely dormant (no polling, no WS messages, one startup log line).
X_BEARER_TOKEN=

# Which backend the match chatter feature fetches from: cli | api | auto
# (default: auto). auto prefers the X API when X_BEARER_TOKEN is set, else
# falls back to the local `twitter` CLI when it resolves on PATH, else stays
# dormant. An explicit cli/api value does not fall back to the other backend.
CHATTER_FETCHER=auto

# Optional override for the local `twitter` CLI binary path (the "cli" chatter
# backend). Leave empty to resolve via `which twitter`, then ~/.local/bin and
# ~/.agent-reach/bin. Only relevant on machines where the CLI is installed —
# never set this on a deploy target without the CLI (e.g. Railway).
TWITTER_CLI_PATH=
